# Generated by Cargo
# will have compiled files and executables
**/target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# (Since you are building a workspace with binaries, you DO NOT want to ignore this, 
# so we leave it commented out)
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which can generally be ignored
*.pdb
*.ilk
*.exp
*.lib

# macOS standard ignores
.DS_Store

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo